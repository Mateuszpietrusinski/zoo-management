<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_AnimalAdmission" targetNamespace="http://zoo.example.com/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.12.0">
  <bpmn:process id="Process_AnimalAdmission" name="Animal Admission to Enclosure" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Zoo manager submits admission request" />
    <bpmn:task id="Task_RecordRequest" name="Record admission request" />
    <bpmn:exclusiveGateway id="Gateway_HealthCheckRequired" name="Origin = external?" />
    <bpmn:task id="Task_PerformHealthCheck" name="Perform health check" />
    <bpmn:exclusiveGateway id="Gateway_AnimalCleared" name="Animal cleared?" />
    <bpmn:task id="Task_SelectEnclosure" name="Select suitable enclosure" />
    <bpmn:exclusiveGateway id="Gateway_EnclosureAvailable" name="Suitable enclosure available?" />
    <bpmn:task id="Task_PlaceAnimal" name="Place animal in enclosure" />
    <bpmn:exclusiveGateway id="Gateway_ZookeeperAssigned" name="Enclosure already has zookeeper?" />
    <bpmn:task id="Task_AssignZookeeper" name="Assign zookeeper to enclosure" />
    <bpmn:task id="Task_ConfirmAdmission" name="Confirm admission" />
    <bpmn:endEvent id="EndEvent_Admitted" name="Admission complete" />
    <bpmn:endEvent id="EndEvent_NotAdmitted" name="Not admitted / Quarantine" />
    <bpmn:endEvent id="EndEvent_NoEnclosure" name="Admission failed - No enclosure" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_RecordRequest" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_RecordRequest" targetRef="Gateway_HealthCheckRequired" />
    <bpmn:sequenceFlow id="Flow_3" name="Yes" sourceRef="Gateway_HealthCheckRequired" targetRef="Task_PerformHealthCheck" />
    <bpmn:sequenceFlow id="Flow_4" name="No" sourceRef="Gateway_HealthCheckRequired" targetRef="Task_SelectEnclosure" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_PerformHealthCheck" targetRef="Gateway_AnimalCleared" />
    <bpmn:sequenceFlow id="Flow_6" name="Cleared" sourceRef="Gateway_AnimalCleared" targetRef="Task_SelectEnclosure" />
    <bpmn:sequenceFlow id="Flow_7" name="Not cleared" sourceRef="Gateway_AnimalCleared" targetRef="EndEvent_NotAdmitted" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_SelectEnclosure" targetRef="Gateway_EnclosureAvailable" />
    <bpmn:sequenceFlow id="Flow_9" name="Yes" sourceRef="Gateway_EnclosureAvailable" targetRef="Task_PlaceAnimal" />
    <bpmn:sequenceFlow id="Flow_10" name="No" sourceRef="Gateway_EnclosureAvailable" targetRef="EndEvent_NoEnclosure" />
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_PlaceAnimal" targetRef="Gateway_ZookeeperAssigned" />
    <bpmn:sequenceFlow id="Flow_12" name="No" sourceRef="Gateway_ZookeeperAssigned" targetRef="Task_AssignZookeeper" />
    <bpmn:sequenceFlow id="Flow_13" name="Yes" sourceRef="Gateway_ZookeeperAssigned" targetRef="Task_ConfirmAdmission" />
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_AssignZookeeper" targetRef="Task_ConfirmAdmission" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_ConfirmAdmission" targetRef="EndEvent_Admitted" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AnimalAdmission">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_AnimalAdmission">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
