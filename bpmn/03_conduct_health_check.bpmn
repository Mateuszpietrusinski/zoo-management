<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_HealthCheck" targetNamespace="http://zoo.example.com/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.12.0">
  <bpmn:process id="Process_HealthCheck" name="Conduct Health Check" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Health check requested" />
    <bpmn:task id="Task_CreateRequest" name="Create or receive health check request" />
    <bpmn:task id="Task_RetrieveAnimal" name="Veterinarian retrieves animal record" />
    <bpmn:task id="Task_PerformExamination" name="Perform examination">
      <bpmn:outgoing>Flow_0xow6je</bpmn:outgoing>
    </bpmn:task>
    <bpmn:task id="Task_RecordResult" name="Record result">
      <bpmn:incoming>Flow_0xow6je</bpmn:incoming>
    </bpmn:task>
    <bpmn:exclusiveGateway id="Gateway_ResultType" name="Result type?" />
    <bpmn:task id="Task_ScheduleFollowUp" name="Schedule follow-up or treatment" />
    <bpmn:task id="Task_Escalate" name="Escalate / urgent treatment" />
    <bpmn:endEvent id="EndEvent_Healthy" name="Complete" />
    <bpmn:endEvent id="EndEvent_FollowUp" name="Follow-up scheduled" />
    <bpmn:endEvent id="EndEvent_Critical" name="Escalated" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_CreateRequest" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_CreateRequest" targetRef="Task_RetrieveAnimal" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_RetrieveAnimal" targetRef="Task_PerformExamination" />
    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_RecordResult" targetRef="Gateway_ResultType" />
    <bpmn:sequenceFlow id="Flow_9" name="Healthy" sourceRef="Gateway_ResultType" targetRef="EndEvent_Healthy" />
    <bpmn:sequenceFlow id="Flow_10" name="Need follow-up" sourceRef="Gateway_ResultType" targetRef="Task_ScheduleFollowUp" />
    <bpmn:sequenceFlow id="Flow_11" name="Critical" sourceRef="Gateway_ResultType" targetRef="Task_Escalate" />
    <bpmn:sequenceFlow id="Flow_12" sourceRef="Task_ScheduleFollowUp" targetRef="EndEvent_FollowUp" />
    <bpmn:sequenceFlow id="Flow_13" sourceRef="Task_Escalate" targetRef="EndEvent_Critical" />
    <bpmn:sequenceFlow id="Flow_0xow6je" sourceRef="Task_PerformExamination" targetRef="Task_RecordResult" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_HealthCheck">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_HealthCheck">
