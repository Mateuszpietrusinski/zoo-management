      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AnyAnimals_di" bpmnElement="Gateway_AnyAnimals" isMarkerVisible="true">
        <dc:Bounds x="655" y="245" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="715" y="256" width="72" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_FeedAnimals_di" bpmnElement="Task_FeedAnimals">
        <dc:Bounds x="770" y="320" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RecordCompleted_di" bpmnElement="Task_RecordCompleted">
        <dc:Bounds x="930" y="230" width="100" height="80" />
