          <dc:Bounds x="1075" y="295" width="71" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_NotDue_di" bpmnElement="EndEvent_NotDue">
        <dc:Bounds x="413" y="390" width="36" height="36" />
