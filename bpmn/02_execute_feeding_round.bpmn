<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_FeedingRound" targetNamespace="http://zoo.example.com/bpmn" exporter="bpmn-js (https://demo.bpmn.io)" exporterVersion="18.12.0">
  <bpmn:process id="Process_FeedingRound" name="Execute Feeding Round" isExecutable="false">
    <bpmn:startEvent id="StartEvent_1" name="Zookeeper requests feeding round for enclosure" />
    <bpmn:task id="Task_RetrieveSchedule" name="Retrieve feeding schedule for enclosure" />
    <bpmn:exclusiveGateway id="Gateway_FeedingDue" name="Current time = scheduled time?" />
    <bpmn:exclusiveGateway id="Gateway_ZookeeperAssigned" name="Zookeeper assigned to enclosure?" />
    <bpmn:exclusiveGateway id="Gateway_AnyAnimals" name="Any animals in enclosure?" />
    <bpmn:task id="Task_FeedAnimals" name="Feed animals in enclosure" />
    <bpmn:task id="Task_RecordCompleted" name="Record feeding completed" />
    <bpmn:endEvent id="EndEvent_Done" name="Feeding round complete" />
    <bpmn:endEvent id="EndEvent_NotDue" name="Not due / Feeding not executed" />
    <bpmn:endEvent id="EndEvent_Abort" name="Abort - Zookeeper not assigned" />
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_RetrieveSchedule" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_RetrieveSchedule" targetRef="Gateway_FeedingDue" />
    <bpmn:sequenceFlow id="Flow_3" name="No" sourceRef="Gateway_FeedingDue" targetRef="EndEvent_NotDue" />
    <bpmn:sequenceFlow id="Flow_4" name="Yes" sourceRef="Gateway_FeedingDue" targetRef="Gateway_ZookeeperAssigned" />
    <bpmn:sequenceFlow id="Flow_5" name="No" sourceRef="Gateway_ZookeeperAssigned" targetRef="EndEvent_Abort" />
    <bpmn:sequenceFlow id="Flow_6" name="Yes" sourceRef="Gateway_ZookeeperAssigned" targetRef="Gateway_AnyAnimals" />
    <bpmn:sequenceFlow id="Flow_7" name="Yes" sourceRef="Gateway_AnyAnimals" targetRef="Task_FeedAnimals" />
    <bpmn:sequenceFlow id="Flow_8" name="No" sourceRef="Gateway_AnyAnimals" targetRef="Task_RecordCompleted" />
    <bpmn:sequenceFlow id="Flow_9" sourceRef="Task_FeedAnimals" targetRef="Task_RecordCompleted" />
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_RecordCompleted" targetRef="EndEvent_Done" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_FeedingRound">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_FeedingRound">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="152" y="252" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="126" y="295" width="88" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_RetrieveSchedule_di" bpmnElement="Task_RetrieveSchedule">
        <dc:Bounds x="240" y="230" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_FeedingDue_di" bpmnElement="Gateway_FeedingDue" isMarkerVisible="true">
        <dc:Bounds x="395" y="245" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="378" y="207" width="84" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_ZookeeperAssigned_di" bpmnElement="Gateway_ZookeeperAssigned" isMarkerVisible="true">
