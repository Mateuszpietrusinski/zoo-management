        <di:waypoint x="980" y="190" />
        <di:waypoint x="980" y="230" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="820" y="170" width="15" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_9_di" bpmnElement="Flow_9">
        <di:waypoint x="870" y="360" />
        <di:waypoint x="980" y="360" />
